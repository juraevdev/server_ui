# Copy to .env and edit before deploy
# cp .env.example .env

# Required in production
DJANGO_SECRET_KEY=change-me-use-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=server.it-zone.uz,localhost,127.0.0.1

CSRF_TRUSTED_ORIGINS=https://server.it-zone.uz,http://server.it-zone.uz

DOCKER_CONTAINER_PREFIX=panel-

# Public HTTP port (nginx)
HTTP_PORT=80
