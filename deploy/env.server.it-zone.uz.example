# Production config for server.it-zone.uz
# cp deploy/env.server.it-zone.uz.example .env
#
# Panel uses host port 8080 only (does NOT bind :80 or :443).
# Existing server nginx on :80 stays untouched — add proxy snippet below.

DJANGO_SECRET_KEY=change-me-use-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=server.it-zone.uz,localhost,127.0.0.1

CSRF_TRUSTED_ORIGINS=https://server.it-zone.uz,http://server.it-zone.uz

DOCKER_CONTAINER_PREFIX=panel-

# Host port for docker-panel-nginx (change only if 8080 is also busy)
HTTP_PORT=8080
